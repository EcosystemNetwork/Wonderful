# Nebius AI Studio — OpenAI-compatible LLM inference (agent reasoning & self-improvement)
# Only the API key is required. Generate one in your Nebius project at https://studio.nebius.com
VITE_NEBIUS_API_KEY=your_nebius_api_key_here
# Best default: Qwen3-235B-Instruct (frontier-class + clean JSON at ~0.85s/call).
# Max-capability alt: deepseek-ai/DeepSeek-V4-Pro (~2.1s/call).
# Run `npm run nebius:models` to list models available to your account.
VITE_NEBIUS_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507

# Nebius AI Cloud console identifiers (reference only — NOT sent to the inference API)
VITE_NEBIUS_PROJECT_ID=project-e00a898kpr00dr28vrewyf
VITE_NEBIUS_TENANT_USER_ID=tenantuseraccount-e00cr4vga00dbmmszb
VITE_NEBIUS_AI_TENANT_ID=aitenant-e00pjzpecsqg8m9mfb

# InsForge — auth, database (agent_runs, agent_memories), storage (characters bucket)
# URL is the `oss_host` from .insforge/project.json; key from `npx @insforge/cli secrets get ANON_KEY`
VITE_INSFORGE_URL=https://your-app.us-east.insforge.app
VITE_INSFORGE_ANON_KEY=your_insforge_anon_key_here

# Meshy.ai — 3D character generation, rigging, animation
VITE_MESHY_API_KEY=your_meshy_api_key_here
